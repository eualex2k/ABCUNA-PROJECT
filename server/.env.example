# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ARQUIVO DE CONFIGURAÇÃO DE VARIÁVEIS DE AMBIENTE (ABCUNA BACKEND)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Porta na qual o Express escutará localmente
PORT=3001

# Endereço da API do seu projeto Supabase
# Encontre em: Dashboard do Supabase -> Project Settings -> API
SUPABASE_URL=https://sua-url-do-supabase.supabase.co

# Chave de acesso administrativo SERVICE_ROLE do seu projeto Supabase
# ATENÇÃO: Nunca exponha ou salve esta chave no frontend. Ela dá super-poderes no banco.
# Encontre em: Dashboard do Supabase -> Project Settings -> API -> service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_do_supabase_aqui

# Modo Somente Leitura (Read-Only) de Homologação
# true  -> Permite apenas consultas à IA. Bloqueia alterações físicas (mensalidades, escalas, etc.)
# false -> Libera fluxo de gravação completo após auditoria de estabilidade
READ_ONLY_MODE=true
JWT_SECRET=your_jwt_secret_here
